# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://<db_user>:<db_password>@<db_host>/<db_name>?sslmode=require&channel_binding=require

# Redis
REDIS_HOST=<redis_host e.g. localhost>
REDIS_PORT=<redis_port e.g. 6379>

# Google OAuth
GOOGLE_CLIENT_ID=<your_google_oauth_client_id>
GOOGLE_CLIENT_SECRET=<your_google_oauth_client_secret>

# Session
SESSION_SECRET=<a_long_random_secret_string>

# Queue Configuration
WORKER_CONCURRENCY=<number_of_concurrent_workers e.g. 5>
MAX_EMAILS_PER_HOUR=<max_emails_per_hour e.g. 200>
EMAIL_DELAY_MS=<delay_between_emails_in_ms e.g. 2000>

# Server
PORT=<backend_port e.g. 3001>
FRONTEND_URL=<frontend_origin e.g. http://localhost:5173>